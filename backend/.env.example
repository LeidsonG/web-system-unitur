# Banco de dados MySQL (XAMPP local)
DATABASE_URL="mysql://root:@localhost:3306/smunitur"

# JWT Secret — OBRIGATÓRIO (mínimo 16 caracteres).
# Em produção, gere um valor aleatório forte, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque_este_valor_por_uma_string_aleatoria_longa_e_segura"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# CORS — URL do frontend
FRONTEND_URL="http://localhost:3000"

# Upload de imagens
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads"
